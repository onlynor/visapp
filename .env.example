# ==========================================
# 自然语言数据可视化工作台配置示例
# ==========================================

# 前台访问密码
# 可以按需自定义
FRONTEND_PASSWORD=24343

# OpenAI 兼容接口配置（可选）
# 请填写你自己的 API Key、Base URL 和模型名称
# Base URL 应指向 OpenAI 兼容 API 根地址，不要填网站首页
# 当前优先调用 /v1/chat/completions，必要时会自动尝试 /v1/responses
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
